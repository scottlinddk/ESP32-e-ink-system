#pragma once

// ============================================================================
// ESP32 Display Configuration
// ============================================================================
// Copy this file to config.h and fill in your values
// NEVER commit config.h to git (it contains credentials)
// ============================================================================

// WiFi Configuration
#define WIFI_SSID     "YourNetworkName"
#define WIFI_PASSWORD "YourNetworkPassword"

// Backend API Configuration
#define API_BASE_URL  "https://api.yourdomain.com"  // e.g., https://esp32-api.example.com
#define USER_ID       "your-user-uuid"              // Your Clerk/Supabase user ID
#define LICENSE_KEY   "your-license-key"            // Device license key from dashboard
#define FIRMWARE_VERSION "1.0.0"                    // Firmware version for OTA checks

// Display Refresh
#define REFRESH_MINUTES 30  // Must match dashboard setting for optimal battery life

// GPIO Pin Configuration (Waveshare 2.13" e-Paper HAT V2)
#define PIN_CS   5    // Chip Select (SPI)
#define PIN_DC   17   // Data/Command
#define PIN_RST  16   // Hardware Reset
#define PIN_BUSY 4    // Busy indicator (active high)

// SPI pins (fixed on ESP32)
#define PIN_MOSI 23   // SPI Data In (DIN)
#define PIN_CLK  18   // SPI Clock (CLK)
#define PIN_MISO 19   // SPI Data Out (not used but defined for completeness)

// Battery Monitoring (optional, comment out if not using)
#define PIN_BATTERY_ADC 35  // GPIO35 (ADC1_7) - typical ESP32 battery ADC pin
#define BATTERY_ALERT_THRESHOLD 3.0  // Volts - alert if below this

// Deep Sleep Configuration
#define DEEP_SLEEP_ENABLED 1        // Set to 1 to enable deep sleep
#define DEEP_SLEEP_DURATION_SEC 900 // 15 minutes (must match REFRESH_MINUTES)

// RTC Memory ID (for deep sleep wake reason tracking)
#define RTC_MEMORY_ID 33

// Debug & Logging
#define DEBUG_ENABLED 1              // Set to 1 for debug serial output
#define DEBUG_BAUD 115200
#define LOG_API_RESPONSES 1          // Log full API response bodies (verbose)

// Connection Timeouts
#define WIFI_CONNECT_TIMEOUT_SEC 20
#define API_REQUEST_TIMEOUT_MS 15000

// Fallback Data (cached display on backend failure)
#define USE_FALLBACK_DATA 1          // Display last successful fetch if API fails
#define FALLBACK_DATA_MAX_AGE_HOURS 24

// Feature Flags
#define FEATURE_OTA_UPDATES 1        // Enable Over-The-Air firmware updates
#define FEATURE_BATTERY_REPORTING 1  // Report battery level to backend
#define FEATURE_CONNECTIVITY_MONITORING 1  // Track WiFi signal strength

// Optional: Custom Data Display Preferences
// (Can also be managed from dashboard preferences endpoint)
#define DEFAULT_DISPLAY_MODE 0  // 0 = Energy prices, 1 = Weather, 2 = News
