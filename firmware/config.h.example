#pragma once

// ============================================================================
// ESP32 Display Configuration
// ============================================================================
// Copy this file to config.h and fill in your values.
// NEVER commit config.h to git (it contains credentials).
//
// NOTE: WiFi credentials, API URL, and user credentials are no longer set
// here — they are provisioned at runtime via the captive-portal AP on first
// boot.  The defines below control hardware pins, feature flags, and timeouts.
// ============================================================================

// ── Arduino IDE Board Selection ──────────────────────────────────────────────
// When using Arduino IDE (not PlatformIO), uncomment the define for your board.
// PlatformIO selects the board automatically via -e esp32dev or -e elecrow_213.
//
// #define ELECROW_EPAPER_213   // Elecrow CrowPanel 2.13" (ESP32-S3)
//                              // Leave commented for Waveshare 2.13" HAT (ESP32-WROOM-32)
// ─────────────────────────────────────────────────────────────────────────────

// Default API URL pre-filled in the captive-portal setup page.
// Override via build flag: -D PROVISION_DEFAULT_API_URL=\"https://...\"
#ifndef PROVISION_DEFAULT_API_URL
#define PROVISION_DEFAULT_API_URL "https://your-api.vercel.app"
#endif

// Firmware version (used for OTA checks and build metadata)
#define FIRMWARE_VERSION "1.0.0"

// Display Refresh interval (minutes) — used when deep sleep is disabled
#define REFRESH_MINUTES 30

// GPIO Pin Configuration
// Board is selected at build time via the PlatformIO environment:
//   pio run -e esp32dev     → Waveshare 2.13" HAT on ESP32-WROOM-32
//   pio run -e elecrow_213  → Elecrow CrowPanel 2.13" on ESP32-S3

#ifdef ELECROW_EPAPER_213
// Elecrow CrowPanel ESP32 2.13" E-Paper (ESP32-S3)
// Pins are the Elecrow board defaults — do NOT change these
// unless you have modified the EPD library's DEV_Config.h as well.
#define PIN_CS   14   // Chip Select (SPI)
#define PIN_DC   13   // Data/Command
#define PIN_RST  10   // Hardware Reset
#define PIN_BUSY 9    // Busy indicator (active high)
#define PIN_MOSI 11   // SPI MOSI (DIN)
#define PIN_CLK  12   // SPI Clock
#define PIN_MISO -1   // Not used
#else
// Waveshare 2.13" e-Paper HAT V2 (ESP32-WROOM-32)
#define PIN_CS   5    // Chip Select (SPI)
#define PIN_DC   17   // Data/Command
#define PIN_RST  16   // Hardware Reset
#define PIN_BUSY 4    // Busy indicator (active high)
#define PIN_MOSI 23   // SPI Data In (DIN)
#define PIN_CLK  18   // SPI Clock (CLK)
#define PIN_MISO 19   // SPI Data Out (not used but defined for completeness)
#endif

// Battery Monitoring
#define PIN_BATTERY_ADC 35           // GPIO35 (ADC1_7)
#define BATTERY_ALERT_THRESHOLD 3.0  // Volts — alert if below this

// Deep Sleep Configuration
#define DEEP_SLEEP_ENABLED 1        // Set to 1 to enable deep sleep
#define DEEP_SLEEP_DURATION_SEC 900 // 15 minutes (must match REFRESH_MINUTES)

// RTC Memory ID (for deep sleep wake reason tracking)
#define RTC_MEMORY_ID 33

// Debug & Logging
#define DEBUG_ENABLED 1      // Set to 1 for debug serial output
#define DEBUG_BAUD 115200
#define LOG_API_RESPONSES 1  // Log full API response bodies (verbose)

// Connection Timeouts
#define WIFI_CONNECT_TIMEOUT_SEC 20
#define API_REQUEST_TIMEOUT_MS 15000

// Fallback Data (cached display on backend failure)
#define USE_FALLBACK_DATA 1
#define FALLBACK_DATA_MAX_AGE_HOURS 24

// Feature Flags
#define FEATURE_OTA_UPDATES 1
#define FEATURE_BATTERY_REPORTING 1
#define FEATURE_CONNECTIVITY_MONITORING 1

// Optional: Custom Data Display Preferences
// (Can also be managed from the dashboard preferences endpoint)
#define DEFAULT_DISPLAY_MODE 0  // 0 = Energy prices, 1 = Weather, 2 = News
