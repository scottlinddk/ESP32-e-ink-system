{
  "name": "esp32-e-ink-system",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"frontend,backend\" -c \"cyan,magenta\" \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend && npm run build -w backend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "typecheck": "npm run typecheck -w frontend && npm run typecheck -w backend",
    "flash": "bash firmware/scripts/flash.sh upload",
    "flash:build": "bash firmware/scripts/flash.sh build",
    "flash:monitor": "bash firmware/scripts/flash.sh monitor",
    "flash:full": "bash firmware/scripts/flash.sh flash",
    "flash:clean": "bash firmware/scripts/flash.sh clean",
    "flash:elecrow": "bash firmware/scripts/flash.sh upload --elecrow",
    "flash:elecrow:build": "bash firmware/scripts/flash.sh build --elecrow",
    "flash:elecrow:monitor": "bash firmware/scripts/flash.sh monitor --elecrow",
    "flash:elecrow:full": "bash firmware/scripts/flash.sh flash --elecrow",
    "flash:elecrow:clean": "bash firmware/scripts/flash.sh clean --elecrow",
    "arduino:setup": "bash firmware/scripts/setup_arduino_ide.sh",
    "arduino:setup:elecrow": "bash firmware/scripts/setup_arduino_ide.sh --elecrow"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
