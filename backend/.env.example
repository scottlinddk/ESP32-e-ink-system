PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Default firmware — served at /firmware/default.bin.
# When set, the backend proxies this URL for esp-web-tools flashing (avoids CORS issues).
# Use a GitHub Releases asset URL, e.g.:
#   https://github.com/scottlinddk/ESP32-e-ink-system/releases/download/v1.0.0/firmware.bin
# Leave blank if you place firmware/builds/default.bin locally instead.
DEFAULT_FIRMWARE_URL=
DEFAULT_FIRMWARE_VERSION=1.0.0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Clerk
CLERK_SECRET_KEY=sk_test_your_key
CLERK_PUBLISHABLE_KEY=pk_test_your_key

# Third-party API keys (fallback if user hasn't added their own)
OPENWEATHERMAP_API_KEY=your_key
NEWS_API_KEY=your_key

# JWT (for future custom auth if needed)
JWT_SECRET=your_random_secret_at_least_32_chars

# AES-256-GCM key for encrypting user API keys at rest
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here
